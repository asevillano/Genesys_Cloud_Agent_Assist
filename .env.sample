# ───────────── Azure OpenAI (STT + Summary) ─────────────
# Leave AZURE_OPENAI_API_KEY empty to authenticate with Entra ID
# (DefaultAzureCredential) — make sure `az login` is done and your principal
# has the "Cognitive Services OpenAI User" role on the resource.
AZURE_OPENAI_ENDPOINT=https://<your-aoai>.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-01-preview
# Realtime transcription deployment (must support gpt-4o-mini-transcribe)
AZURE_OPENAI_TRANSCRIBE_DEPLOYMENT=gpt-4o-mini-transcribe
# Chat deployment for wrap-up summary / categorization
AZURE_OPENAI_SUMMARY_DEPLOYMENT=gpt-4.1-mini

# ───────────── Azure AI Foundry Agent (v2 — Responses API) ─────────────
# Agents v2 identifies agents by *name* (not by GUID). Use the agent name as
# shown in the Foundry portal (project.agents.create_version was called with
# this `agent_name`).
PROJECT_ENDPOINT=https://<your-foundry-project>.services.ai.azure.com/api/projects/<project>
AGENT_NAME=my-agent
# Optional: comma-separated list of agent names the user can switch between in the UI
ALLOWED_AGENT_NAMES=

# ───────────── Cosmos DB (optional, persistence) ─────────────
# Leave COSMOS_ENDPOINT empty to disable persistence.
# Leave COSMOS_KEY empty to authenticate with Entra ID
# (DefaultAzureCredential). The principal needs a Cosmos DB Data Contributor
# role assignment on the account.
COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
COSMOS_KEY=
COSMOS_DATABASE=agentassist
COSMOS_CONTAINER=conversations

# ───────────── Runtime ─────────────
# Language hint passed to the Realtime STT (BCP-47, e.g. "es", "en", "tr")
STT_LANGUAGE=es
# Categories used by the wrap-up summary
CONVERSATION_CATEGORIES=Invoices,Products,Support,Billing
# HTTP/WS port
PORT=8000
# Set to "1" to require this shared secret on /audiohook (header X-API-KEY)
AUDIOHOOK_API_KEY=
